# Universe 647 — Phase 4: Sophon (AI Brain)
# Copy to .env, fill in values, then run: make encrypt

# ==============================================================================
# Global (must match stacks/core/.env)
# ==============================================================================

DOMAIN=home.yourdomain.com
TZ=America/Los_Angeles
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_MUST_MATCH_CORE

# ==============================================================================
# LiteLLM (LLM API Gateway)
# ==============================================================================

# Master key for LiteLLM API authentication
# Generate: openssl rand -base64 32 | tr -d '\n'
LITELLM_MASTER_KEY=CHANGE_ME_GENERATE_KEY

# Google Gemini API Key (for tool-caller model)
# Create at: https://aistudio.google.com/apikey
GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY

# Anthropic API Key (for smart model)
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY

# ==============================================================================
# Open WebUI
# ==============================================================================

# Secret key for session encryption
# Generate: openssl rand -base64 32 | tr -d '\n'
WEBUI_SECRET_KEY=CHANGE_ME_GENERATE_SECRET

# ==============================================================================
# mcpo (MCP-to-OpenAPI Proxy)
# ==============================================================================

# API key for mcpo endpoint authentication
# Generate: openssl rand -base64 32 | tr -d '\n'
MCPO_API_KEY=CHANGE_ME_GENERATE_KEY

# ==============================================================================
# MCP Server Tokens
# These are used by mcpo's child MCP servers to authenticate with services.
# Injected into config.template.json automatically via entrypoint.sh.
# ==============================================================================

# Monica CRM API token (Settings > API in Monica UI)
MONICA_API_TOKEN=CHANGE_ME_MONICA_TOKEN

# Vikunja API token (Settings > API Tokens in Vikunja UI)
VIKUNJA_API_TOKEN=CHANGE_ME_VIKUNJA_TOKEN
