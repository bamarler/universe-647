# Universe 647 — Phase 3: Data Stack
# Copy to .env, fill in values, then run: make encrypt

# ==============================================================================
# Global
# ==============================================================================

# Your domain (must match core stack)
DOMAIN=home.yourdomain.com

# Timezone
TZ=America/Los_Angeles

# ==============================================================================
# PostgreSQL (shared — must match stacks/core/.env)
# ==============================================================================

POSTGRES_USER=postgres

# Must match the password in stacks/core/.env
POSTGRES_PASSWORD=CHANGE_ME_MUST_MATCH_CORE

# ==============================================================================
# Monica CRM
# ==============================================================================

# Generate: docker run --rm monica:4-apache php artisan key:generate --show
# Or: echo "base64:$(openssl rand -base64 32)"
MONICA_APP_KEY=CHANGE_ME_GENERATE_APP_KEY

# Generate each: openssl rand -base64 32 | tr -d '\n'
MONICA_DB_PASSWORD=CHANGE_ME_GENERATE_PASSWORD
MONICA_DB_ROOT_PASSWORD=CHANGE_ME_GENERATE_PASSWORD

# ==============================================================================
# n8n Workflow Automation
# ==============================================================================

# Encryption key for stored credentials
# Generate: openssl rand -base64 32 | tr -d '\n'
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_KEY

# JWT secret for user sessions
# Generate: openssl rand -base64 64 | tr -d '\n'
N8N_JWT_SECRET=CHANGE_ME_GENERATE_SECRET

# ==============================================================================
# SMTP (for Monica email notifications — optional)
# ==============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=CHANGE_ME_GMAIL_APP_PASSWORD
SMTP_FROM_ADDRESS=your-email@gmail.com
