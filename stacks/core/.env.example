# Universe 647 — Phase 2: Core Infrastructure
# Copy to .env, fill in values, then run: make encrypt

# ==============================================================================
# Global
# ==============================================================================

# Your domain (used in Caddyfile and Authelia)
DOMAIN=home.yourdomain.com

# Timezone (used by containers that need it)
TZ=America/Los_Angeles

# ==============================================================================
# PostgreSQL
# ==============================================================================

# Database superuser
POSTGRES_USER=postgres

# Generate: openssl rand -base64 32 | tr -d '\n'
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# ==============================================================================
# Authelia (SSO + 2FA)
# ==============================================================================

# Generate each with: openssl rand -base64 64 | tr -d '\n'
AUTHELIA_JWT_SECRET=CHANGE_ME_GENERATE_64_CHAR_SECRET
AUTHELIA_SESSION_SECRET=CHANGE_ME_GENERATE_64_CHAR_SECRET
AUTHELIA_STORAGE_ENCRYPTION_KEY=CHANGE_ME_GENERATE_64_CHAR_SECRET

# ==============================================================================
# Tailscale (Mesh VPN)
# ==============================================================================

# Create at: https://login.tailscale.com/admin/settings/keys
# Use: Reusable, Tagged with tag:server, Ephemeral OFF
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXXXXXX-YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY

# Hostname shown in Tailscale admin console
TS_HOSTNAME=universe-647

# ==============================================================================
# Caddy (Reverse Proxy)
# ==============================================================================

# Cloudflare API Token — needed for DNS challenge (auto HTTPS certs)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone > DNS > Edit
CLOUDFLARE_API_TOKEN=CHANGE_ME_CLOUDFLARE_API_TOKEN

# ==============================================================================
# CrowdSec (Intrusion Detection)
# ==============================================================================

# Generate AFTER first CrowdSec start:
#   docker exec crowdsec cscli bouncers add caddy-bouncer
# Then paste the key here, re-encrypt, and restart Caddy
CROWDSEC_API_KEY=CHANGE_ME_GENERATE_AFTER_FIRST_START

# ==============================================================================
# NUT (UPS Monitoring)
# ==============================================================================

# Password for NUT API access (host upsmon connects with this)
# Generate: openssl rand -base64 16 | tr -d '\n'
NUT_API_PASSWORD=CHANGE_ME_GENERATE_PASSWORD

# ==============================================================================
# Uptime Kuma (used only by: make setup-monitors — not injected at runtime)
# ==============================================================================

# Credentials you set during Uptime Kuma's first-run setup
UPTIME_KUMA_USER=admin
UPTIME_KUMA_PASS=CHANGE_ME_SET_AFTER_FIRST_LOGIN
